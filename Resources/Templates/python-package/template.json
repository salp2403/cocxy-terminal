{
  "id": "python-package",
  "name": "Python Package",
  "description": "Creates a local Python package with unittest coverage.",
  "variables": [
    {
      "name": "project_name",
      "prompt": "Project name",
      "default": "cocxy-tool",
      "required": true
    },
    {
      "name": "package_name",
      "prompt": "Python package name",
      "default": "cocxy_tool",
      "required": true
    }
  ],
  "hooks": {
    "post": [
      "python -m unittest discover -s tests"
    ]
  }
}
