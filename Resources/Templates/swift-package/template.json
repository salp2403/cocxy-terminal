{
  "id": "swift-package",
  "name": "Swift Package",
  "description": "Creates a local Swift package with a test target.",
  "variables": [
    {
      "name": "project_name",
      "prompt": "Project name",
      "default": "CocxyTool",
      "required": true
    },
    {
      "name": "module_name",
      "prompt": "Swift module name",
      "default": "CocxyTool",
      "required": true
    }
  ],
  "hooks": {
    "post": [
      "swift test"
    ]
  }
}
