{
  "id": "php-composer",
  "name": "PHP Composer",
  "description": "Creates a local Composer-style PHP package skeleton.",
  "variables": [
    {
      "name": "project_name",
      "prompt": "Project name",
      "default": "cocxy-php-tool",
      "required": true
    },
    {
      "name": "namespace",
      "prompt": "PHP namespace",
      "default": "CocxyTool",
      "required": true
    }
  ],
  "hooks": {
    "post": [
      "php -l src/Greeter.php"
    ]
  }
}
