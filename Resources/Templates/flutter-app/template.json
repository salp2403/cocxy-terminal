{
  "id": "flutter-app",
  "name": "Flutter App",
  "description": "Creates a small local Flutter app skeleton.",
  "variables": [
    {
      "name": "project_name",
      "prompt": "Project name",
      "default": "cocxy_flutter_app",
      "required": true
    },
    {
      "name": "app_title",
      "prompt": "App title",
      "default": "Cocxy App",
      "required": true
    }
  ],
  "hooks": {
    "post": [
      "flutter test"
    ]
  }
}
